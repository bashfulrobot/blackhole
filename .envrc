# Check required tools
./scripts/check-deps.sh

# Load secrets from 1Password (kong-lab vault)
# TF_VAR_ prefixed vars are automatically picked up by OpenTofu
export TF_VAR_project_id=$(op read "op://kong-lab/gcp/project-id" 2>/dev/null || echo "")
export TF_VAR_region=$(op read "op://kong-lab/gcp/primary-region" 2>/dev/null || echo "")
export TF_VAR_zone="${TF_VAR_region}-a"
export GCP_SECONDARY_REGION=$(op read "op://kong-lab/gcp/secondary-region" 2>/dev/null || echo "")
export TF_VAR_kong_license=$(op read "op://kong-lab/kong-license/license" 2>/dev/null || echo "")
export TF_VAR_konnect_install_token=$(op read "op://kong-lab/konnect/install-token" 2>/dev/null || echo "")
export TF_VAR_konnect_pat=$(op read "op://kong-lab/konnect/automation-pat" 2>/dev/null || echo "")
export TF_VAR_konnect_org_id=$(op read "op://kong-lab/konnect/org-id" 2>/dev/null || echo "")

if [ -z "$TF_VAR_project_id" ]; then
  echo "Warning: Could not load secrets from 1Password. Ensure 1Password is unlocked."
fi
